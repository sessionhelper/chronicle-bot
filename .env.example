# Discord bot token — get from https://discord.com/developers/applications
DISCORD_TOKEN=

# S3-compatible object storage (Hetzner, Backblaze B2, MinIO, etc.)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ttrpg-dataset-raw
S3_ENDPOINT=https://fsn1.your-objectstorage.com

# Local buffer directory for in-progress recordings
LOCAL_BUFFER_DIR=./sessions

# Logging level
LOG_LEVEL=INFO
